# Source data (large Excel files — share separately, not committed)
Source Data/

# Extracted output CSVs — regenerate by running main.py
# Use wildcard (not trailing slash) so file-level exceptions below work
Extracted Data/*
# Exception: hand-sourced macro inputs that cannot be regenerated by the pipeline
!Extracted Data/10_external_macro_data.csv

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# OS artefacts
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/
